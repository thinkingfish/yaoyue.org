---
import BaseLayout from "@layouts/BaseLayout.astro";
---

<BaseLayout
	title="Talks - Yao Yue"
	description="Conference talks and presentations by Yao Yue"
>
	<div class="relative min-h-[100lvh]">
		<section class="site-container relative pt-12 text-center md:pt-20">
			<h1 class="text-xl sm:text-3xl text-primary-600">Talks</h1>

			<div class="mt-8 text-base-700">
				<p class="mb-4">Slides from various conference talks and presentations.</p>
				<a
					href="https://github.com/thinkingfish/misc/tree/main/talks"
					class="inline-block btn rounded-md px-6 py-3"
					target="_blank"
					rel="noopener noreferrer"
				>
					View slides on GitHub
				</a>
			</div>

			<div class="mt-8">
				<a href="/" class="text-primary-600 hover:text-primary-700 underline">
					← Back home
				</a>
			</div>
		</section>
	</div>
</BaseLayout>
