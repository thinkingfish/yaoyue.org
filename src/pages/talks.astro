---
import TalkEntry from "@components/TalkEntry.astro";
import BaseLayout from "@layouts/BaseLayout.astro";

import { SITE } from "@/data/site";
import { podcastsInterviews, publicTalks } from "@/data/talks";
import { breadcrumbSchema } from "@/lib/structured-data";

const jsonLd = breadcrumbSchema([
	{ name: "Home", url: `${SITE.url}/` },
	{ name: "Talks", url: `${SITE.url}/talks/` },
]);
---

<BaseLayout
	title="Talks - Yao Yue"
	description="Public talks, conference presentations, podcasts, and interviews by Yao Yue on caching, distributed systems, and performance engineering at scale."
	jsonLd={jsonLd}
>
	<div class="relative min-h-[100lvh]">
		<section class="site-container relative pt-12 text-center md:pt-20">
			<h1 class="text-primary-600 text-xl sm:text-3xl">Talks</h1>

			<div class="text-base-700 dark:text-base-300 mt-8">
				<p>Public talks, podcasts, and interviews.</p>
			</div>

			<div class="mt-12 pl-7 text-left sm:pl-0">
				<h2 class="text-primary-600 text-lg font-medium sm:text-xl">Public Talks</h2>
				<ul class="mt-4 space-y-3">
					{publicTalks.map((talk) => <TalkEntry talk={talk} />)}
				</ul>

				<h2 class="text-primary-600 mt-12 text-lg font-medium sm:text-xl">Podcasts & Interviews</h2>
				<ul class="mt-4 space-y-3">
					{podcastsInterviews.map((talk) => <TalkEntry talk={talk} />)}
				</ul>
			</div>

			<div class="mt-12 text-center">
				<a
					href="https://github.com/thinkingfish/misc/tree/main/talks"
					class="btn inline-block rounded-md px-6 py-3"
					target="_blank"
					rel="noopener noreferrer"
				>
					More slides on GitHub
				</a>
			</div>

			<div class="mt-12">
				<a href="/" class="text-primary-600 hover:text-primary-700 underline"> &larr; Back home </a>
			</div>
		</section>
	</div>
</BaseLayout>
