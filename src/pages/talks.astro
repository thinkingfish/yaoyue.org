---
import BaseLayout from "@layouts/BaseLayout.astro";

import { conferenceTalks, podcastsInterviews } from "@/data/talks";
---

<BaseLayout title="Talks - Yao Yue" description="Conference talks and presentations by Yao Yue">
	<div class="relative min-h-[100lvh]">
		<section class="site-container relative pt-12 text-center md:pt-20">
			<h1 class="text-primary-600 text-xl sm:text-3xl">Talks</h1>

			<div class="text-base-700 dark:text-base-300 mt-8">
				<p class="mb-4">Conference talks, podcasts, and interviews.</p>
				<a
					href="https://github.com/thinkingfish/misc/tree/main/talks"
					class="btn inline-block rounded-md px-6 py-3"
					target="_blank"
					rel="noopener noreferrer"
				>
					View slides on GitHub
				</a>
			</div>

			<div class="mt-12 text-left">
				<h2 class="text-primary-600 text-lg font-medium sm:text-xl">Conference Talks</h2>
				<ul class="mt-4 space-y-6">
					{
						conferenceTalks.map((talk) => (
							<li>
								<a
									href={talk.recordingUrl}
									class="text-base-800 dark:text-base-200 hover:text-primary-600 dark:hover:text-primary-500 font-medium transition-colors"
									target="_blank"
									rel="noopener noreferrer"
								>
									{talk.title}
									<svg
										class="ml-1 inline-block h-3.5 w-3.5 align-baseline"
										viewBox="0 0 24 24"
										fill="none"
										stroke="currentColor"
										stroke-width="2.5"
										stroke-linecap="round"
										stroke-linejoin="round"
									>
										<>
											<path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
											<polyline points="15 3 21 3 21 9" />
											<line x1="10" y1="14" x2="21" y2="3" />
										</>
									</svg>
								</a>
								{talk.slidesUrl && (
									<a
										href={talk.slidesUrl}
										class="border-base-300 dark:border-base-700 text-base-600 dark:text-base-400 hover:border-primary-600 hover:text-primary-600 dark:hover:border-primary-500 dark:hover:text-primary-500 ml-2 inline-block rounded border px-1.5 py-0.5 align-baseline text-[0.65rem] leading-none font-semibold tracking-wide uppercase transition-colors"
										target="_blank"
										rel="noopener noreferrer"
										aria-label={`Slides (PDF) for ${talk.title}`}
									>
										PDF
									</a>
								)}
								<p class="text-base-500 dark:text-base-400 mt-1 text-sm">{talk.event}</p>
							</li>
						))
					}
				</ul>

				<h2 class="text-primary-600 mt-12 text-lg font-medium sm:text-xl">Podcasts & Interviews</h2>
				<ul class="mt-4 space-y-6">
					{
						podcastsInterviews.map((talk) => (
							<li>
								<a
									href={talk.recordingUrl}
									class="text-base-800 dark:text-base-200 hover:text-primary-600 dark:hover:text-primary-500 font-medium transition-colors"
									target="_blank"
									rel="noopener noreferrer"
								>
									{talk.title}
									<svg
										class="ml-1 inline-block h-3.5 w-3.5 align-baseline"
										viewBox="0 0 24 24"
										fill="none"
										stroke="currentColor"
										stroke-width="2.5"
										stroke-linecap="round"
										stroke-linejoin="round"
									>
										<>
											<path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
											<polyline points="15 3 21 3 21 9" />
											<line x1="10" y1="14" x2="21" y2="3" />
										</>
									</svg>
								</a>
								{talk.slidesUrl && (
									<a
										href={talk.slidesUrl}
										class="border-base-300 dark:border-base-700 text-base-600 dark:text-base-400 hover:border-primary-600 hover:text-primary-600 dark:hover:border-primary-500 dark:hover:text-primary-500 ml-2 inline-block rounded border px-1.5 py-0.5 align-baseline text-[0.65rem] leading-none font-semibold tracking-wide uppercase transition-colors"
										target="_blank"
										rel="noopener noreferrer"
										aria-label={`Slides (PDF) for ${talk.title}`}
									>
										PDF
									</a>
								)}
								<p class="text-base-500 dark:text-base-400 mt-1 text-sm">{talk.event}</p>
							</li>
						))
					}
				</ul>
			</div>

			<div class="mt-12">
				<a href="/" class="text-primary-600 hover:text-primary-700 underline"> &larr; Back home </a>
			</div>
		</section>
	</div>
</BaseLayout>
